{
  "name": "@fifo/convee",
  "version": "0.10.0",
  "exports": "./src/index.ts",
  "imports": {
    "@/": "./src/",
    "@convee": "./src/index.ts",

    "@test/": "./test/",

    "std/": "https://deno.land/std@0.224.0/",

    "@std/assert": "jsr:@std/assert@^1.0.0",
    "@std/testing": "jsr:@std/testing@^1.0.0"
  },

  "tasks": {
    "test": "deno test -A --parallel --clean --ignore='_*/,.legacy/' --coverage=coverage src test",
    "test:unit": "deno test -A --parallel --clean --ignore='_*/,src/v1,**/*.integration.test.ts' --coverage=coverage src",
    "test:integration": "deno test -A --parallel --clean --ignore='_*/,src/v1,**/*.unit.test.ts' --coverage=coverage test",
    "test:file": "deno test -A --parallel --clean --ignore='_*/,src/v1' src test"
  },
  "lint": {
    "include": ["src/", "test/"],
    "exclude": [
      "src/testdata/",
      "src/fixtures/**/*.ts",
      "**/*.test.ts",
      "src/index-test.ts",
      "src/test/utils/examples/**/*.ts"
    ],
    "rules": {
      "tags": ["recommended"],
      "include": ["ban-untagged-todo"],
      "exclude": ["no-unused-vars"]
    }
  }
}
